rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && currentUserProfile().exists
        && currentUserProfile().data.role == 'admin'
        && currentUserProfile().data.status == 'approved';
    }

    function isApproved() {
      return isSignedIn()
        && currentUserProfile().exists
        && currentUserProfile().data.status == 'approved';
    }

    function isStaff() {
      return isSignedIn()
        && currentUserProfile().exists
        && currentUserProfile().data.role == 'staff'
        && currentUserProfile().data.status == 'approved';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get: if isSignedIn() && (
        isAdmin()
        || (isApproved() && resource.data.active == true)
        || (isApproved() && resource.data.createdBy == request.auth.uid)
      );
      allow list: if isSignedIn() && (
        isAdmin()
        || isApproved()
      );

      allow create: if isSignedIn() && (isStaff() || isAdmin())
        && request.resource.data.status == 'pending'
        && request.resource.data.active == false
        && request.resource.data.featured == false
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isSignedIn() && (
        isAdmin()
        || (
          (isStaff() || isAdmin())
          && resource.data.status == 'pending'
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.status == resource.data.status
          && request.resource.data.active == resource.data.active
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdByName == resource.data.createdByName
        )
      );

      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow get: if isSignedIn() && (
        isAdmin()
        || (isStaff() && resource.data.staffId == request.auth.uid)
      );
      allow list: if isSignedIn() && (
        isAdmin()
        || isStaff()
      );
      allow create: if isSignedIn() && (isStaff() || isAdmin()) && request.resource.data.staffId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
